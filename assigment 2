<script>


function getRadio(name) {

    const selected =
        document.querySelector(
            'input[name="' + name + '"]:checked'
        );

    return selected
        ? selected.value
        : "Not provided";

}


function value(id) {

    const element =
        document.getElementById(id);

    return element &&
           element.value.trim()
        ? element.value
        : "Not provided";

}


function submitReport() {


    if (
        !document.getElementById("claimNo").value.trim() ||
        !document.getElementById("workerName").value.trim() ||
        !document.getElementById("reportDate").value ||
        !document.getElementById("certification").checked
    ) {

        alert(
            "Please fill Claim Number, Worker Name, Report Date and accept the Certification."
        );

        return;

    }


    const receiptNo =
        "WPR-" +
        new Date().getFullYear() +
        "-" +
        Math.floor(
            100000 + Math.random() * 900000
        );


    document.getElementById(
        "receiptNumber"
    ).innerText = receiptNo;


    document.getElementById(
        "submissionTime"
    ).innerText =
        new Date().toLocaleString();


    document.getElementById(
        "rClaimNo"
    ).innerText =
        value("claimNo");


    document.getElementById(
        "rAppId"
    ).innerText =
        value("workerAppId");


    document.getElementById(
        "rWorkerName"
    ).innerText =
        value("workerName");


    document.getElementById(
        "rReportDate"
    ).innerText =
        value("reportDate");


    document.getElementById(
        "rReturnProgress"
    ).innerText =
        value("returnProgress");


    document.getElementById(
        "rWorkStatus"
    ).innerText =
        getRadio("workStatus");


    document.getElementById(
        "rReturnedDate"
    ).innerText =
        value("returnedDate");


    document.getElementById(
        "rExpectedDate"
    ).innerText =
        value("expectedReturnDate");


    document.getElementById(
        "rDuties"
    ).innerText =
        getRadio("duties");


    document.getElementById(
        "rConcerns"
    ).innerText =
        value("returnConcerns");


    document.getElementById(
        "rEmployerContact"
    ).innerText =
        value("employerContact");


    document.getElementById(
        "rRecovery"
    ).innerText =
        getRadio("recovery");


    document.getElementById(
        "rRecoveryComments"
    ).innerText =
        value("recoveryComments");


    document.getElementById(
        "rPain"
    ).innerText =
        getRadio("pain");


    document.getElementById(
        "rMedical"
    ).innerText =
        getRadio("medicalStatus");


    document.getElementById(
        "rProvider"
    ).innerText =
        value("providerName");


    document.getElementById(
        "rLastTreatment"
    ).innerText =
        value("lastProvider")
        + " | "
        + value("lastTreatmentDate");


    document.getElementById(
        "rNextTreatment"
    ).innerText =
        value("nextProvider")
        + " | "
        + value("nextTreatmentDate");


    document.getElementById(
        "rMedication"
    ).innerText =
        getRadio("medicationStatus")
        + " | "
        + value("medication");


    document.getElementById(
        "rExercises"
    ).innerText =
        getRadio("exerciseStatus")
        + " | "
        + value("exercises");


    document.getElementById(
        "rAdditional"
    ).innerText =
        value("additionalInfo");


    document.getElementById(
        "reportForm"
    ).style.display = "none";


    document.getElementById(
        "receipt"
    ).style.display = "block";


    window.scrollTo({

        top: 0,

        behavior: "smooth"

    });


}


function newReport() {

    location.reload();

}


</script>


